#include <stdio.h>
#include <stdlib.h>
#include <errno.h>
#include <string.h>
#include "mutex_sim.h"

static const char *
message_type_name(MessageType type)
{
    switch (type) {
    case REQUEST:
        return "REQUEST";
    case REPLY:
        return "REPLY";
    case RELEASE:
        return "RELEASE";
    default:
        return "UNKNOWN";
    }
}

int
main(void)
{
    Process processes[3];
    Message *msg = NULL;
    int rc;
    size_t i;

    for (i = 0; i < 3; i++) {
        if (process_init(&processes[i]) == -1) {
            perror("process_init");
            exit(EXIT_FAILURE);
        }
    }

    puts("Initial processes:");
    for (i = 0; i < 3; i++)
        print_process(&processes[i]);

    puts("\nP0 requests the critical section...");
    if (request_critical_section(processes, 3, 0) == -1) {
        perror("request_critical_section");
        exit(EXIT_FAILURE);
    }

    puts("\nAfter request_critical_section:");
    for (i = 0; i < 3; i++)
        print_process(&processes[i]);

    printf("\nP0 state: requesting=%d request_timestamp=%d replies_needed=%d\n",
           processes[0].requesting,
           processes[0].request_timestamp,
           processes[0].replies_needed);

    puts("\nP1 receives one message...");
    rc = receive_message(&processes[1], &msg);
    if (rc == -1) {
        perror("receive_message");
        exit(EXIT_FAILURE);
    }
    if (rc == 1) {
        puts("P1 inbox is empty.");
    } else {
        printf("P1 received %s from P%d to P%d with timestamp %d\n",
               message_type_name(msg->type),
               msg->sender,
               msg->receiver,
               msg->timestamp);
        free(msg);
    }
    print_process(&processes[1]);

    puts("\nP2 receives one message...");
    msg = NULL;
    rc = receive_message(&processes[2], &msg);
    if (rc == -1) {
        perror("receive_message");
        exit(EXIT_FAILURE);
    }
    if (rc == 1) {
        puts("P2 inbox is empty.");
    } else {
        printf("P2 received %s from P%d to P%d with timestamp %d\n",
               message_type_name(msg->type),
               msg->sender,
               msg->receiver,
               msg->timestamp);
        free(msg);
    }
    print_process(&processes[2]);

    puts("\nFinal process states:");
    for (i = 0; i < 3; i++)
        print_process(&processes[i]);

    for (i = 0; i < 3; i++)
        queue_destroy_full(&processes[i].inbox);

    return 0;
}
