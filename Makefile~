CC = gcc
CFLAGS = -Wall -Wextra -g -Iinclude
SRC_DIR = src
TEST_DIR = tests

QUEUE_OBJ = $(SRC_DIR)/queue.o
TEST_QUEUE_OBJ = $(TEST_DIR)/test_queue.o

TARGET = test_queue

all: $(TARGET)

$(TARGET): $(QUEUE_OBJ) $(TEST_QUEUE_OBJ)
	$(CC) $(CFLAGS) -o $@ $(QUEUE_OBJ) $(TEST_QUEUE_OBJ)

$(SRC_DIR)/queue.o: $(SRC_DIR)/queue.c include/queue.h
	$(CC) $(CFLAGS) -c $< -o $@

$(TEST_DIR)/test_queue.o: $(TEST_DIR)/test_queue.c include/queue.h
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(SRC_DIR)/*.o $(TEST_DIR)/*.o $(TARGET)
